# =========================================================================
# Atmosphere-AI Environment Variables Template
# Copy this file to '.env' and fill in settings to configure remote database
# or physical sensors.
#
# Note: If '.env' is left blank or unconfigured, the application runs 
# automatically in offline simulation mode using a local SQLite database.
# =========================================================================

# Supabase PostgreSQL Connection String (Remote Integration)
# Leave blank to run locally using SQLite (atmosphere_ai.db).
SUPABASE_DB_URL=

# OpenWeatherMap API Key (Optional)
# Leave blank to use free, keyless Open-Meteo API automatically.
OPENWEATHERMAP_API_KEY=

# Default location coordinates (New York City by default)
DEFAULT_LAT=40.7128
DEFAULT_LON=-74.0060

# Physical PMS5003 sensor settings
SENSOR_SERIAL_PORT=/dev/ttyS0
SENSOR_BAUDRATE=9600

# Remote SSH Sensor configurations
SSH_HOST=192.168.1.242
SSH_USER=admin
SSH_PORT=22
